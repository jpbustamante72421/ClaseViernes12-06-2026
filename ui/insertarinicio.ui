  <property name="styleSheet">
   <string notr="true">/* --- Paleta Premium: Concrete &amp; Navy --- */
/* Fondo: #E5E7EB (Gris cemento claro - sólido y profesional) */
/* Elementos: #F3F4F6 (Blanco humo para campos - profundidad) */
/* Acento: #1E3A8A (Azul Navy profundo - seriedad y confianza) */
/* Texto: #1F2937 (Gris carbón oscuro - excelente contraste) */

QDialog {
    background-color: #E5E7EB;
}

QLabel {
    color: #374151;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

QLineEdit {
    background-color: #F3F4F6;
    border: 1.5px solid #D1D5DB;
    border-radius: 4px; /* Bordes rectos para un look sólido */
    padding: 10px 12px;
    font-size: 14px;
    color: #111827;
    selection-background-color: #1E3A8A;
    selection-color: #FFFFFF;
}

QLineEdit:focus {
    border: 1.5px solid #1E3A8A;
    background-color: #FFFFFF;
}

/* Botón Principal (Navy Power) */
QPushButton {
    background-color: #1E3A8A;
    color: #FFFFFF;
    border-radius: 4px;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 800;
    border: none;
}

QPushButton:hover {
    background-color: #1E40AF;
}

QPushButton:pressed {
    background-color: #172554;
    padding-top: 12px;
}

/* Botón Secundario (Solid Steel) */
QPushButton#btnCancelar {
    background-color: #D1D5DB;
    color: #374151;
}

QPushButton#btnCancelar:hover {
    background-color: #9CA3AF;
    color: #111827;
}</string>
