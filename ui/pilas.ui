  <property name="styleSheet">
   <string notr="true">/* --- Paleta Premium: Forest &amp; Concrete --- */
/* Fondo: #E5E7EB (Gris cemento claro) */
/* Elementos: #F3F4F6 (Blanco humo) */
/* Acento: #064E3B (Verde Bosque Profundo - elegancia, estabilidad) */
/* Texto: #1F2937 (Gris carbón oscuro) */

QDialog {
    background-color: #E5E7EB;
}

QLabel {
    color: #374151;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

QLineEdit {
    background-color: #F3F4F6;
    border: 1.5px solid #D1D5DB;
    border-radius: 4px;
    padding: 10px 12px;
    font-size: 14px;
    color: #111827;
    selection-background-color: #064E3B;
    selection-color: #FFFFFF;
}

QLineEdit:focus {
    border: 1.5px solid #064E3B;
    background-color: #FFFFFF;
}

/* Botón Principal (Forest Power) */
QPushButton {
    background-color: #064E3B;
    color: #FFFFFF;
    border-radius: 4px;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 800;
    border: none;
}

QPushButton:hover {
    background-color: #065F46;
}

QPushButton:pressed {
    background-color: #022C22;
    padding-top: 12px;
}

/* Botón Secundario (Solid Steel) */
QPushButton#btnCancelar {
    background-color: #D1D5DB;
    color: #374151;
}

QPushButton#btnCancelar:hover {
    background-color: #9CA3AF;
    color: #111827;
}</string>
