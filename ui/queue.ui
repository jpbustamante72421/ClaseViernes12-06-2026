  <property name="styleSheet">
   <string notr="true">/* --- Paleta Premium: Burnt Orange &amp; Minimalist --- */
/* Fondo: #FAFAFA (Blanco brillante muy limpio) */
/* Elementos: #FFFFFF (Blanco puro para campos) */
/* Acento: #EA580C (Naranja Quemado - energía y enfoque) */
/* Texto: #262626 (Negro suave, alta legibilidad) */

QDialog {
    background-color: #FAFAFA;
}

QLabel {
    color: #404040;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
}

QLineEdit {
    background-color: #FFFFFF;
    border: 1.5px solid #E5E5E5;
    border-radius: 4px;
    padding: 10px 12px;
    font-size: 14px;
    color: #171717;
    selection-background-color: #EA580C;
    selection-color: #FFFFFF;
}

QLineEdit:focus {
    border: 1.5px solid #EA580C;
    background-color: #FFFFFF;
}

/* Botón Principal (Energy Power) */
QPushButton {
    background-color: #EA580C;
    color: #FFFFFF;
    border-radius: 4px;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 800;
    border: none;
}

QPushButton:hover {
    background-color: #C2410C;
}

QPushButton:pressed {
    background-color: #9A3412;
    padding-top: 12px;
}

/* Botón Secundario (Soft Neutral) */
QPushButton#btnCancelar {
    background-color: #E5E5E5;
    color: #525252;
}

QPushButton#btnCancelar:hover {
    background-color: #D4D4D4;
    color: #171717;
}</string>
