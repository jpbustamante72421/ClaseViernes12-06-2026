  <property name="styleSheet">
   <string notr="true">/* --- Fondo: Gris Acero Profundo --- */
QDialog {
    background-color: #2D3436; 
}

/* --- TÍTULOS Y ETIQUETAS --- */
QLabel {
    color: #F1F2F6;
    font-weight: 700;
}

/* Título Sistema de Banco - Grande y blanco */
QLabel#label {
    font-size: 44px;
    margin-bottom: 30px;
    color: #FFFFFF;
    font-weight: 900;
}

/* Campos de entrada */
QLineEdit {
    background-color: #485460;
    border: 1px solid #74808A;
    border-radius: 6px;
    padding: 10px;
    color: #FFFFFF;
    font-size: 16px;
    font-weight: 600;
}

/* --- Etiquetas de datos (&quot;Vacíos&quot;) con letra más pequeña --- */
QLabel#label_3, QLabel#label_4 {
    background-color: #485460;
    border: 1px solid #74808A;
    border-radius: 4px;
    padding: 8px;
    color: #FFFFFF;
    font-size: 12px; /* Letra más pequeña y técnica */
    font-weight: 500;
}

/* --- BOTONES: ESCALA DE GRISES --- */

/* Botón Turno: Gris claro */
QPushButton#btnTurno {
    background-color: #DCDDE1;
    color: #2D3436;
    font-weight: 800;
    border-radius: 6px;
    padding: 8px;
}

/* Botón Atender: Gris medio */
QPushButton#btnAtender {
    background-color: #B2BEC3;
    color: #2D3436;
    font-weight: 800;
    border-radius: 6px;
    padding: 8px;
}

/* Botón Cerrar: Gris oscuro */
QPushButton#btnCerrar {
    background-color: #7F8C8D;
    color: #FFFFFF;
    font-weight: 800;
    border-radius: 6px;
    padding: 8px;
}</string>
