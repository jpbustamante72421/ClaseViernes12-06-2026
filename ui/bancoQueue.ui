  <property name="styleSheet">
   <string notr="true">/* --- Estilo: Emerald Banking Pro --- */

QDialog {
    background-color: #F0FDF4; /* Fondo verde muy claro y relajante */
}

/* Título imponente */
QLabel#label { 
    color: #065F46; 
    font-size: 40px; 
    font-weight: 900; 
    text-transform: uppercase;
    letter-spacing: -1px;
    margin-bottom: 30px;
}

/* Etiquetas pequeñas y elegantes */
QLabel {
    color: #064E3B;
    font-size: 12px;
    font-weight: 700;
}

/* Input con borde sutil pero marcado */
QLineEdit {
    background-color: #FFFFFF;
    border: 2px solid #A7F3D0;
    border-radius: 6px;
    padding: 10px;
    font-size: 14px;
    color: #064E3B;
}

QLineEdit:focus {
    border: 2px solid #059669;
}

/* --- BOTONES CON PERSONALIDAD --- */

/* Botón Turno: Acción Principal */
QPushButton#btnTurno { 
    background-color: #059669; 
    color: white; 
    border-radius: 6px; 
    font-weight: 800;
    padding: 10px;
}
QPushButton#btnTurno:hover { background-color: #047857; }

/* Botón Atender: Acción de Proceso */
QPushButton#btnAtender { 
    background-color: #34D399; 
    color: #064E3B; 
    border-radius: 6px; 
    font-weight: 800;
    padding: 10px;
}
QPushButton#btnAtender:hover { background-color: #10B981; }

/* Botón Cerrar: Acción de Salida */
QPushButton#btnCerrar { 
    background-color: #D1FAE5; 
    color: #065F46; 
    border-radius: 6px; 
    font-weight: 800;
    padding: 10px;
}
QPushButton#btnCerrar:hover { background-color: #A7F3D0; }
</string>
